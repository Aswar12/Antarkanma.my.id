[mysqld]
# Server identification and networking
server-id = 2
bind-address = 0.0.0.0
default-time-zone = '+08:00'

# Replication logs
relay-log = mysql-relay-bin
log_bin = mysql-bin
binlog_do_db = antarkanma
sync_binlog = 1

# GTID Replication
gtid_mode = ON
enforce_gtid_consistency = ON
log_slave_updates = ON
read_only = ON
super_read_only = ON

# Performance tuning for read-only slave
innodb_buffer_pool_size = 512M
innodb_flush_log_at_trx_commit = 0
max_connections = 500

# Connection timeout
wait_timeout = 28800
interactive_timeout = 28800

# Character set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Skip events that could write to the binary log
skip-log-bin
skip-slave-start

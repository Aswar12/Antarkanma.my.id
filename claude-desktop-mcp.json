{
  "mcpServers": {
    "laravel-antarkanma": {
      "command": "php",
      "args": [
        "C:\\laragon\\www\\Antarkanma\\mcp-server.php"
      ],
      "env": {
        "APP_ENV": "local"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\laragon\\www\\Antarkanma"
      ],
      "env": {
        "ALLOWED_PATHS": "C:\\laragon\\www\\Antarkanma\\app,C:\\laragon\\www\\Antarkanma\\database,C:\\laragon\\www\\Antarkanma\\routes,C:\\laragon\\www\\Antarkanma\\resources,C:\\laragon\\www\\Antarkanma\\storage,C:\\laragon\\www\\Antarkanma\\config"
      }
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "YOUR_NOTION_TOKEN_HERE"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_YOUR_GITHUB_TOKEN_HERE"
      }
    }
  }
}
